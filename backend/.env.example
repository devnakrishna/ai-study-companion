# 🔐 AI Study Companion - Backend Environment Variables Example

# Google Gemini API Key for AI Quiz Generation & Evaluation
# Obtain this from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Database connection URL (SQLAlchemy compatible)
# Format: mysql+pymysql://username:password@host:port/database_name
# Format (PostgreSQL): postgresql://username:password@host:port/database_name
# Format (SQLite): sqlite:///./sql_app.db
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/ai_study_companion

# JWT Secret Key used for signing/encrypting access tokens (use a long random string)
JWT_SECRET=your_jwt_secret_key_here
